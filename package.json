{
  "name": "secret-models-back",
  "version": "1.0.0",
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "start": "NODE_ENV=production bun run dist/index.mjs",
    "build": "drizzle-kit generate && tsdown",
    "build:linux": "drizzle-kit generate && tsdown",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "auth:migrate": "bunx @better-auth/cli migrate"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/eden": "^1.4.9",
    "@elysiajs/openapi": "^1.4.15",
    "aws4fetch": "^1.0.20",
    "better-auth": "^1.6.10",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "drizzle-typebox": "^0.3.3",
    "elysia": "latest",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "bun-types": "latest",
    "drizzle-kit": "^0.31.10",
    "tsdown": "^0.22.0"
  },
  "type": "module",
  "module": "src/index.js"
}
